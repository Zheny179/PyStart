{
  "name": "py_start",
  "type": "module",
  "version": "0.2.8",
  "description": "Интерактивный учебник по Python",
  "license": "MIT",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint:style": "stylelint \"src/**/*.{scss,astro}\"",
    "lint:style:fix": "stylelint \"src/**/*.{scss,astro}\" --fix",
    "format": "prettier --write --plugin=prettier-plugin-astro \"src/**/*.{astro,js,jsx,ts,tsx,mjs,css,json,md}\"",
    "format:check": "prettier --check --diff --plugin=prettier-plugin-astro \"src/**/*.{astro,js,jsx,ts,tsx,mjs,css,json,md}\""
  },
  "dependencies": {
    "astro": "6.4.4",
    "astro-icon": "1.1.5",
    "gsap": "3.15.0",
    "sass": "1.100.0"
  },
  "devDependencies": {
    "@types/node": "25.9.2",
    "autoprefixer": "10.5.2",
    "cssnano": "8.0.2",
    "postcss-html": "1.8.1",
    "postcss-scss": "4.0.9",
    "prettier": "3.8.4",
    "prettier-plugin-astro": "0.14.1",
    "stylelint": "17.13.0",
    "stylelint-config-recess-order": "7.7.0",
    "stylelint-config-standard-scss": "17.0.0"
  },
  "browserslist": [
    "defaults",
    "not ie > 0",
    "not op_mini all",
    "not baidu > 0",
    "not kaios > 0",
    "not bb > 0",
    "not and_qq > 0",
    "not and_uc > 0"
  ]
}
