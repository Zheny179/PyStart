---
import Card from '@/components/Card/Card.astro'
import Ellipse from '@/components/Ellipse/Ellipse.astro'
import {aboutBookCards} from '@/data/aboutBookData'
import SecondarySection
  from '@/components/Section/SecondarySection/SecondarySection.astro'
---

<SecondarySection
  className="how-it-works"
  title="Как устроен учебник"
  desc="Учебник разделен на последовательные главы, каждая из которых закрывает конкретный пласт знаний и создает фундамент для следующей темы."
>
  <Ellipse
    color="purple"
    bottom="-260px"
    left="-360px"
  />
  <Ellipse
    color="purple"
    top="-300px"
    right="-400px"
  />
  <Card items={aboutBookCards} />
</SecondarySection>

<script>
  import {gsap} from 'gsap'
  import {ScrollTrigger} from 'gsap/ScrollTrigger'

  gsap.registerPlugin(ScrollTrigger)

  const hasVisited = sessionStorage.getItem('logo_animated')

  if (!hasVisited) {
    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: '.how-it-works',
        start: 'top 50%',
      }
    })

    tl.from('.how-it-works .section__header', {
      opacity: 0,
      y: 50,
      duration: 0.6
    })
      .from('.card__item', {
        opacity: 0,
        y: 50,
        duration: 0.6,
        stagger: 0.2
      }, '-=0.2')
  }
</script>
