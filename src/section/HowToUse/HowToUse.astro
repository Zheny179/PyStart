---
import SecondarySection
  from "@/layouts/Section/SecondarySection/SecondarySection.astro"
import Accordion from "@/components/Accordion/Accordion.astro"
import AccordionGroup from "@/components/AccordionGroup/AccordionGroup.astro"

const workingProcessSteps = [
  {
    title: "Ручной набор кода вместо пассивного чтения",
    desc: "Эффективное усвоение программирования требует активной работы с материалом, а не простого ознакомления с теорией. Настоятельно рекомендуем не ограничиваться просмотром примеров на экране, а самостоятельно набирать каждый фрагмент в редакторе кода или встроенном интерактивном блоке. Механическое воспроизведение синтаксиса способствует формированию устойчивых навыков, помогает быстрее запомнить правила отступов, оформление строк и особенности вызова функций. При визуальном ознакомлении с работающим кодом возникает иллюзия полного понимания, которая быстро исчезает при первой попытке написать программу самостоятельно. Поэтому относитесь к каждому примеру как к практическому заданию, а не как к простой иллюстрации.",
    isOpen: true,
  },
  {
    title: "Закрепление материала и анализ ошибок",
    desc: "После изучения теоретического раздела обязательно выполняйте встроенные тесты и практические задания. Они предназначены для оперативной проверки глубины усвоения информации. Если ответ оказался неверным, не переходите к следующей теме. Вернитесь к объяснению, найдите конкретное место, где допущена ошибка, внимательно перечитайте его и попробуйте сформулировать правило собственными словами. Программирование — это навык, который развивается через последовательное повторение, осмысление и постепенное усложнение задач. Ведите личные заметки, сохраняйте экспериментальные скрипты в отдельной папке и не избегайте намеренных изменений кода для проверки его устойчивости. Понимание причин возникновения ошибок интерпретатора, умение читать сообщения об ошибках и выявлять точки нарушения логики зачастую ценнее, чем безупречный запуск программы с первой попытки.",
  },
  {
    title: "Регулярность занятий и модификация примеров",
    desc: "Постоянство в обучении значительно важнее разовых интенсивных нагрузок. Рекомендуется уделять материалу от сорока до шестидесяти минут ежедневно, а не концентрировать несколько часов в один день. Короткие, но регулярные занятия способствуют лучшему закреплению информации в памяти и снижают умственную нагрузку. Когда вы убедитесь, что текущая тема усвоена, не спешите открывать следующий раздел. Попробуйте самостоятельно изменить примеры из учебника: добавьте новые условия, усложните циклы, замените типы данных, адаптируйте логику функций под иные задачи. Именно в процессе независимых изменений теория трансформируется в практический навык, а запомненные конструкции становятся инструментами, которыми вы умеете пользоваться осознанно.",
  },
]
---
<SecondarySection
  className="how-to-use"
  title="Как правильно работать с учебником"
>
  <AccordionGroup>
    {workingProcessSteps.map(({title, desc, isOpen}) => (
      <li class="accordion-group__item">
        <Accordion
          title={title}
          name="how-to-use"
          isOpen={isOpen}
        >
          {desc}
        </Accordion>
      </li>
    ))}
  </AccordionGroup>
</SecondarySection>

<script>
  import {gsap} from "gsap"
  import {ScrollTrigger} from "gsap/ScrollTrigger"
  import {TextPlugin} from "gsap/TextPlugin"

  gsap.registerPlugin(ScrollTrigger, TextPlugin)
  const hasVisited = sessionStorage.getItem('logo_animated')

  if (!hasVisited) {

    const items = document.querySelectorAll(".accordion-group__item")

    if (items.length > 0) {
      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: ".how-to-use",
          start: "top 50%",
        }
      })

      gsap.set(items, {opacity: 0, pointerEvents: 'none'})

      items.forEach((item) => {
        const titleElement = item.querySelector(".accordion__title")

        if (titleElement) {
          const originalText = titleElement.textContent || ""
          titleElement.textContent = ""

          tl
            .fromTo('.how-to-use .section__header', {
              opacity: 0
            }, {
              opacity: 1,
              duration: 0.7
            })
            .to(item, {
              opacity: 1,
              duration: 0.4,
            })
            .to(titleElement, {
              text: originalText,
              duration: originalText.length * 0.02,
              ease: "none",
              onStart: () => {
                gsap.set(item, {pointerEvents: "none"})
              },
              onComplete: () => {
                gsap.set(item, {pointerEvents: "auto"})
              }
            }, "-=0.4")
        }
      })
    }
  }
</script>
