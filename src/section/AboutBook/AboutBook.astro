---
import SecondarySection
  from '@/layouts/Section/SecondarySection/SecondarySection.astro'
import './AboutBook.scss'
import TextPlate from "@/components/TextPlate/TextPlate.astro"
import Ellipse from "@/components/Ellipse/Ellipse.astro"
---

<SecondarySection
  className="about-book"
  title="О учебнике"
>
  <Ellipse
    color="white"
    top="0%"
    left="-22%"
    blur="100px"
  />

  <Ellipse
    color="yellow"
    width="500px"
    height="500px"
    bottom="0%"
    right="-23%"
    blur="100px"
  />

  <TextPlate />
</SecondarySection>

<script>
  import {gsap} from 'gsap'
  import {ScrollTrigger} from 'gsap/ScrollTrigger'

  gsap.registerPlugin(ScrollTrigger)

  const hasVisited = sessionStorage.getItem('logo_animated')

  if (!hasVisited) {
    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: '.about-book',
        start: 'top 50%',
      }
    })

    tl.from('.about-book .section__header', {
      opacity: 0,
      y: 50,
      duration: 0.6
    })
      .from('.text-plate__header', {
        opacity: 0,
        x: 50,
        ease: 'power3',
        duration: 0.6,
        stagger: 0.3
      }, '-=0.2')
      .from('.text-plate__body', {
        opacity: 0,
        x: -50,
        ease: 'power3',
        duration: 0.6,
        stagger: 0.3
      }, '-=0.2')
  }

</script>
