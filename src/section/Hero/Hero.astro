---
import './Hero.scss'
import Button from "@/components/Button/Button.astro"
import Ellipse from '@/components/Ellipse/Ellipse.astro'
import arrowLeftIcon from '@/assets/icon/arrow-left.svg'
---

<section class="hero">
  <canvas
    class="hero__bg"
    id="hero-canvas"
  ></canvas>

  <Ellipse
    color="green"
    top="40%"
    left="0%"
  />

  <Ellipse
    width="500px"
    height="500px"
    bottom="33%"
    right="-10%"
  />

  <div class="container hero__inner">
    <h1 class="hero__title">
      Пошаговый интерактивный учебник — от основ до
      продвинутых техник.
      Код с подсветкой синтаксиса, встроенные примеры и тесты.
    </h1>
    <Button
      className="hero__button"
      href="/"
      label="Начать изучение"
      iconName={arrowLeftIcon.src}
    />
  </div>
</section>

<script>
  import {gsap} from 'gsap'

  function animation() {
    gsap.timeline()
      .to('.hero', {opacity: 1, ease: "power2.out"})
      .to('.hero__bg', {opacity: 1, duration: 1}, '-=0.5')
      .fromTo('.hero__title', {x: -20}, {x: 0, duration: 0.4, opacity: 1})
      .fromTo('.hero__button', {y: -20}, {y: 0, duration: 1, opacity: 1})
  }


  const hasVisited = sessionStorage.getItem('logo_animated')

  if (!hasVisited) {
    window.addEventListener('logoAnimationComplete', animation)
  } else {
    animation()
  }
</script>
