---
import './Socials.scss'
import {Icon} from 'astro-icon/components'

interface Props {
  className?: string,
}

const {className} = Astro.props

const socials = [
  {
    icon: 'socials/github',
    link: 'https://github.com/Zheny179',
    title: 'Переход на GitHub',
  },
  {
    icon: 'socials/vk',
    link: 'https://vk.com/doronine777',
    title: 'Переход на VK',
  },
]
---


<div class:list={['soc1als', className]}>
  <ul class="soc1als__list">
    {socials.map(({icon, link, title}) => (
      <li class="soc1als__item">
        <a
          class="soc1als__link"
          href={link}
        >
          <Icon
            class="soc1als__img"
            name={icon}
            title={title}
          />
        </a>
      </li>
    ))}
  </ul>
</div>
