---
import PageLayout from '@/layouts/PageLayout.astro'
import { getCollection, render } from 'astro:content'
import Navigation from '@/components/Navigation/Navigation.astro'
import Button from '@/components/Button/Button.astro'
import ButtonMenu from '@/components/ButtonMenu/ButtonMenu.astro'
import { getChapters } from '@/module/getChapters'

/*
 * getCollection — получить все записи
 */

export async function getStaticPaths() {
  const lessonsCollection = await getCollection('lessons')

  return lessonsCollection.map((lesson) => ({
    params: { id: lesson.id },
    props: { lesson },
  }))
}

const { lesson } = Astro.props

const lessonTitle = lesson.data.title
const chapterData = await getChapters({
  currentLessonId: lesson.id,
})

const { Content, headings } = await render(lesson)

const contentsData = headings.map((heading) => ({
  label: heading.text,
  href: `#${heading.slug}`,
}))
---

<PageLayout title={lesson.data.title}>
  <main>
    <nav class='nav visible-laptop'>
      <ButtonMenu
        mode='white'
        extraAttrs={{ 'data-nav-toggle': 'chapters' }}
      />

      <ButtonMenu
        mode='contents'
        extraAttrs={{ 'data-nav-toggle': 'contents' }}
      />
    </nav>
    <div class='page'>
      <Navigation
        chapter={chapterData}
        mode='chapters'
      />
      <div class='primary-container'>
        <h1>{lesson.data.title}</h1>
        <Content />
      </div>
      <Navigation
        content={contentsData}
        lessonTitle={lessonTitle}
        mode='contents'
      />
    </div>
  </main>
</PageLayout>

<script>
  import CopyCode from '@/module/CopyCode'
  import ScrollSpy from '@/module/ScrollSpy'

  ScrollSpy()
  CopyCode()

  const CLASS_COLLAPSED = 'navigation--collapsed'

  document.querySelectorAll<HTMLElement>('[data-nav-toggle]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const target = btn.dataset.navToggle
      const navEl = document.querySelector(`.navigation--${target}`)
      navEl?.classList.toggle(CLASS_COLLAPSED)
      document.documentElement.classList.toggle('is-lock')
    })
  })
</script>

<style lang='scss'>
  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px;
    gap: 15px;
    border-bottom: 1px solid var(--border-color);
    border-top: 1px solid var(--border-color);
  }

  .aside {
    position: sticky;
    top: calc(100px + fluid(30, 20));

    border: 1px solid var(--border-color);
    border-radius: 0 20px 20px 0;
    padding: 20px;
    width: 390px;
    height: 880px;
    box-shadow: 0 0 12px 0 var(--neon-blue);
    background: var(--bg-overlay);

    &:nth-last-child(1) {
      border-radius: 20px 0 0 20px;
    }

    &__btn {
      @include square(45px);

      color: var(--color-white);
      background-color: transparent;
      border: none;
      padding: 0;
      display: inline-flex;

      &--arrow {
        @include flex-center;

        color: var(--color-black);
        background-color: var(--color-white);
        border-radius: 50%;
      }
    }

    &__header {
      display: flex;
      justify-content: space-between;
    }
  }

  .primary-container {
    width: 100%;
    border-radius: 20px 20px 0 0;
    padding: fluid(25, 5) fluid(30, 20);
    box-shadow: 0 0 12px 0 var(--neon-blue);
    background: var(--bg-overlay);

    @include laptop {
      box-shadow: none;
      background: var(--bg-primary);
    }
  }

  .page {
    --left-aside-width: #{fluid(390, 200)};
    --right-aside-width: #{fluid(390, 200)};

    display: grid;
    padding-top: 20px;
    grid-template-columns: var(--left-aside-width) 3fr var(--right-aside-width);
    column-gap: fluid(60, 0);
    align-items: baseline;
    transition: all 1s ease 0.1s;

    &:has(.navigation--chapters.navigation--collapsed) {
      --left-aside-width: 100px;
    }

    &:has(.navigation--contents.navigation--collapsed) {
      --right-aside-width: 100px;
    }

    @include laptop {
      display: flex;
    }
  }
</style>

<style lang='scss' is:global>
  blockquote {
    border: 2px solid var(--neon-green);
    border-radius: 12px;
    padding: 15px;
    margin: 20px 0;
    font-size: 1.1em;
  }

  code:not(pre code) {
    font-family: var(--font-family-secondary), sans-serif;
    font-size: 18px;
    letter-spacing: -0.1em;
    color: var(--neon-green);
    text-shadow: 0 0 1px var(--neon-green);
    border-radius: 5px;
    padding: 3px;
    box-shadow: 0 0 5px 0 #34c759;
    background: #08080b;
  }

  .astro-code {
    border-radius: var(--border-radius-xl);
    padding: 50px 20px;
    box-shadow: 0 0 12px 0 var(--neon-blue);
    gap: 20px;
    background-color: var(--bg-primary) !important;
    font-weight: 700;
    font-size: 22px;
    margin: 50px 0;
    position: relative;

    code {
      white-space: pre-line;
      word-wrap: break-word;
    }

    &::before {
      content: attr(data-language);
      position: absolute;
      top: 5px;
      left: 20px;
      color: var(--neon-green-alpha-mid);
    }
  }

  .copy-code-button {
    position: absolute;
    top: 5px;
    right: 15px;
  }

  pre.astro-code {
    counter-reset: line;
  }

  h1,
  h2,
  h3,
  h4,
  h5,
  h6 {
    scroll-margin-top: 150px;
  }

  pre.astro-code .line::before {
    counter-increment: line;
    content: counter(line);
    display: inline-block;
    margin-right: 1.5rem;
    text-align: right;
    color: #6a737d;
    user-select: none;
  }

  h1 {
    color: var(--neon-purple);
    text-shadow: 0 0 3px 0 #8a38f5;
  }

  h2 {
    color: var(--neon-pink);
    text-shadow: 0 0 3px 0 var(--neon-pink);
  }

  h3 {
    color: var(--neon-blue);
    text-shadow: 0 0 4px 0 var(--neon-blue);
  }

  h4 {
    color: var(--neon-green);
    text-shadow: 0 0 4px 0 var(--neon-green);
  }

  h5 {
    color: var(--neon-yellow);
    text-shadow: 0 0 4px 0 var(--neon-yellow);
  }

  h6 {
    color: var(--text-primary);
    text-shadow: 0 0 4px 0 #dbdbdb;
  }

  .copy-code-button {
    border: none;
    box-shadow: none;
    font-size: 18px;
    color: var(--neon-green);
    padding: 5px;
  }
</style>
