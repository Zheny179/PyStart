---
import Footer from '@/section/Footer/Footer.astro'
import Header from '@/section/Header/Header.astro'
import '@/styles'

interface Props {
  title: string
}

const { title = 'сайт' } = Astro.props
const currentUrl = Astro.url.pathname

const baseURL = import.meta.env.BASE_URL
---

<!doctype html>
<html lang='ru'>
  <head>
    <meta charset='UTF-8' />
    <meta
      name='viewport'
      content='width=device-width'
    />
    <link
      rel='icon'
      type='image/x-icon'
      href={`${baseURL}favicon.ico`}
    />
    <link
      rel='icon'
      type='image/png'
      sizes='16x16'
      href={`${baseURL}favicon-16x16.png`}
    />
    <link
      rel='icon'
      type='image/png'
      sizes='32x32'
      href={`${baseURL}favicon-32x32.png`}
    />
    <link
      rel='apple-touch-icon'
      sizes='180x180'
      href={`${baseURL}apple-touch-icon.png`}
    />
    <link
      rel='icon'
      type='image/png'
      sizes='192x192'
      href={`${baseURL}android-chrome-192x192.png`}
    />
    <link
      rel='icon'
      type='image/png'
      sizes='512x512'
      href={`${baseURL}android-chrome-512x512.png`}
    />
    <title>Py:Start | {title}</title>
  </head>
  <body>
    <Header currentUrl={currentUrl} />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
